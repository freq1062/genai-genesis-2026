# Portable backend — no external services required (no PostgreSQL, MongoDB, or Redis/Celery).

GOOGLE_API_KEY=your_google_api_key
HF_TOKEN=your_huggingface_token

# Lab API (local Hunyuan3D server)
LOCAL_API_URL=http://dh2020pc01.utm.utoronto.ca:8000
LOCAL_MODEL_PATH=/path/to/hunyuan3d/weights
LOCAL_MODEL_VERSION=hunyuan3d-v2.1

# Asset storage (file-system based)
PROJECTS_DIR=./projects

# Railtracks
RAILTRACKS_LOG_LEVEL=INFO
